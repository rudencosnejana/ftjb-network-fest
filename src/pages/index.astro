---
import "../styles/global.css";
import { Image } from 'astro:assets';

import logo from '../assets/logo.png'; // Image is 1600x900
import coperta from '../assets/coperta.png'; // Image is 1600x900
import brasov from '../assets/brasov.svg'; // Image is 1600x900
import retea from '../assets/retea.svg'; // Image is 1600x900

import Layout from '../layouts/Layout.astro';

---

<Layout>

<header class="fixed w-full bg-white z-100">
    <div class="py-8 px-16 flex flex-row justify-between">
        <Image src={logo} height={64} alt=""/>

        <nav class="flex flex-row items-center gap-4">
            <a class="hover:text-secondary text-primary font-bold text-lg px-4 py-2" href="#manuale">Manuale</a>
            <a class="hover:text-secondary text-primary font-bold text-lg px-4 py-2" href="#program">Program</a>
            <a class="hover:text-secondary text-primary font-bold text-lg px-4 py-2" href="#sponsori-si-parteneri">Sponsori și Parteneri</a>
        </nav>
    </div>
</header>

<div class={ `relative overflow-hidden pt-56 pb-26` }>

    <div class="absolute -top-50 left-0">
        <Image src={coperta} class="" alt=""/>
    </div>
    <div class="absolute top-0 left-0 bg-linear-to-b from-[#2F0060] from-10% via-primary/65 via-70% to-black/90 z-1 w-full h-full"> </div>

    <div class="pl-20 text-white text-[2.75rem] z-10 w-fit" style="position: inherit;">
        <div class="relative w-fit">

            <Image  class="absolute top-1/3 left-1/2"  src={retea} alt=""/>
            <h1 class="text-[10rem] text-shadow-[0.66px_2.66px_15.49px_rgb(0_0_0_/_0.7)] font-extrabold">NETWORK FEST</h1>
            <Image class="absolute left-1/2 top-37 -translate-x-58" src={brasov} alt=""/>


        </div>

        <p class="pt-26">Evenimentul care ne unește</p>

        <div class="py-10">
            <time><b>25 aprilie 2026</b></time>
            <div>Interval orar: <b>11:00-16:00</b></div>
        </div>

        <p>Locația: Afi MALL, zona Food Court</p>
    </div>
</div>

<div>
    <h1 id="manuale" class="bg-green-100 h-screen">Manuale</h1>
</div>

<div>
    <h1 id="program" class="bg-green-100 h-screen">Program</h1>
</div>

<div>
    <h1 id="sponsori-si-parteneri" class="bg-green-100 h-screen">Sponsori și Parteneri</h1>
</div>

</Layout>
