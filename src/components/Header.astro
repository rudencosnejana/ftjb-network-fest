---
import { Image } from "astro:assets";

import logo from "@assets/logo_2.png";
---

<header class="fixed w-screen bg-white z-100 border-b-1 border-black/5">
    <div class="py-6 lg:py-8 px-3 xl:px-26 flex flex-row justify-between">
        <Image loading={'eager'} src={logo} class="object-contain object-left h-[38px] md:h-[54px]" height={54} alt="" />
        <nav class="hidden lg:flex lg:flex-row lg:items-center gap-4">
            <a
                class="hover:text-secondary text-primary font-bold text-lg px-4 py-2"
                href="#program"
            >Program</a>
            <a
                class="hover:text-secondary text-primary font-bold text-lg px-4 py-2"
                href="#participanti"
            >Participanți</a>
        </nav>
    </div>
</header>
