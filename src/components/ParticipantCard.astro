---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

import icon_map from "../content/icon_map.js";

interface Props {
    logo: string;
    title: string;
    links: [string, string][];
    domains: string[];
    description: string;
}

const { logo, title, description, domains, links } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
    "@assets/logo_altii/*.{png,jpg}",
);
---

<div
    class="flex flex-col justify-between items-center w-130 bg-white p-5 py-8 text-black/40 text-center md:border-2 md:rounded-lg md:border-primary/15"
>
    <div class="flex flex-col items-center gap-y-3">
        {
            logo !== "" ? (
                <Image
                    alt=""
                    class="pb-2 max-w-80 h-26 object-contain"
                    height={84}
                    src={images
                        [`/src/assets/logo_altii/${logo}`]()}
                />
            ) : <b class="py-5">{title}</b>
        }
        <div class="flex flex-row flex-wrap gap-1 w-full justify-center">
            {
                domains.map((d) => (
                    <div
                        class="border-2 border-primary text-primary text-xs rounded-full px-3 font-semibold text-no-wrap whitespace-nowrap"
                    >
                        {d}
                    </div>
                ))
            }
        </div>
        <div
            class="text-black/80 text-sm py-4"
        >
            {description}
        </div>
    </div>
    <div class="flex flex-row flex-wrap gap-2">
        {
            links.map(([media, address]) => (
            <a class="block p-1 border-1 border-olive-200/0 hover:border-olive-200 rounded-md hover:bg-olive-50 w-fit" href={address}>{
                    icon_map.get(media) !== undefined ? (
                        <div set:html={icon_map.get(media)}></div>
                    ) : media
                }</a>
            ))
        }
    </div>
</div>
